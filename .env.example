# Environment variables RepoSage reads. Copy to .env and fill in as needed;
# every variable is optional and the tool degrades without it.

# AI enrichment providers (only needed with --enrich / enrich=true).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# GitHub API access for private-repo cloning in the MCP server.
GITHUB_TOKEN=

# OpenTelemetry export for the MCP server ([observability] extra).
OTEL_EXPORTER_OTLP_ENDPOINT=
REPOSAGE_OTEL_CONSOLE=

# Set by GitHub Actions; the github report format appends its summary here.
GITHUB_STEP_SUMMARY=

# Set internally by the audit engine to stop recursive self-audits.
REPOSAGE_INNER_AUDIT=
